
.superpowers/
.claude/worktrees/

# ---- Agent client install (local-only, not platform-neutral) ----
.claude/

# ---- Hermes ----
# Track prompt templates; ignore runtime state (decisions, outcomes, locks)
.hermes/*
!.hermes/prompts/

# ---- Gstack / Gbrain ----
# Ignore operational and machine-specific gstack/gbrain operational noise
docs/gstack/**/brain-cache/
docs/gstack/**/*.json
docs/gstack/**/*.jsonl
docs/gstack/**/.gbrain-*

# Only allow tracking of human-readable documentation and plans
!docs/gstack/**/*.md

# Transient autoplan/skill recovery artifacts (backups, not deliverables)
docs/gstack/**/*-autoplan-restore-*.md

# ---- Environment files ----
.env
.env.*
!.env.example

# ---- Python ----
# Symlink for import resolution — created dynamically by conftest.py
tests/skill_test_environment/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

